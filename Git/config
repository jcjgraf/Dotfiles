[core]
    editor = nvim
    excludesfile = /home/jeanclaude/.config/git/gitignore_global
    pager = delta
[merge]
    tool = vimdiff
[mergetool]
    prompt = true
    keepBackup = false
[mergetool "vimdiff"]
    cmd = nvim -d $BASE $LOCAL $REMOTE $MERGED -c '$wincmd w' -c 'wincmd J'
    #cmd = nvim -d $LOCAL $REMOTE $MERGED -c '$wincmd w' -c 'wincmd J'
[commit]
    gpgSign = true
[gpg]
    program = gpg2
[pull]
    ff = only
[alias]
    s = status
    squashbranch = reset $(git merge-base master $(git rev-parse --abbrev-ref HEAD))
    tree = log --oneline --graph --decorate --all
    csha = rev-parse HEAD
    add-deleted = !git add $(git ls-files --deleted)
    unstage = restore --staged
[init]
    defaultBranch = main
[diff]
    colormoved = default
[interactive]
    diffFilter = delta --color-only
[delta]
    # Enable features
    # - navigate: Jump to next/previous file with n/N
    feature = navigate
    navigate = true  # use n and N to move between diff sections
    dark = true      # or light = true, or omit for auto-detection
    # To diaplay colormoved
    map-styles = bold purple => syntax magenta, bold cyan => syntax blue
[color "status"]
    added = green
    changed = yellow
    untracked = red
[safe]
	directory = /mnt/thumbdrive/Archive
	directory = /mnt/images/Archive
	directory = /mnt/images/Archive/.git
[credential]
	helper = store
