bind index,attach,compose,pager | pipe-entry
bind generic,query,compose t tag-entry
bind index,query T tag-pattern
# bind index,query T untag-pattern
bind generic \; tag-prefix
bind index,pager s decode-copy
bind index,pager ww set-flag
bind index,pager W clear-flag
macro index wr\
    ":set resolve=no\n<clear-flag>N<clear-flag>O:set resolve=yes\n" \
    "mark current as read"
macro index wu\
    "<set-flag>O" \
    "mark current as read"

