# vim: filetype=neomuttrc

### General Key Bindings
# Unbind everything, which adds some default fallback bindings
unbind *
unbind * <Enter>
unbind * <Return>
unbind * <F1>
unbind * <F2>

source './bind.muttrc'

### General Settings
set abort_backspace = false # Do not abort empty prompt on backspace
set abort_key = "<Esc>"
set fast_reply = yes
set markers = no        # Disables the `+` displayed at line wraps
set mailcap_path 	= ~/.config/mutt/mailcap
set print_command="/usr/bin/muttprint -r ~/.config/muttprint/muttprintrc"
unset quit # Disable quitting

## Sorting
# Have two config files, one for threaded, one for flat view and load desired one via macro
# source ~/.config/mutt/nothreads.muttrc
source ~/.config/mutt/threads.muttrc

### Abort on missing attachment
set abort_noattach = yes
set abort_noattach_regex = "\\<(attach(|ed|ments?)|anhängen|angehängt|anhang|anhänge|hängt an)\\>"

### Sidebar
set mail_check_stats  # Check for mails to display stats
set sidebar_visible = yes
set sidebar_width = 35
set sidebar_short_path = yes

### Notmuch
set nm_default_url = "notmuch:///home/jeanclaude/.local/share/mail"
# set nm_query_type = "threads"  # Return threads rather than messages
# bind index,pager \Cf noop
# bind index,pager / noop
# macro index / "<vfolder-from-query>" "show only messages matching a notmuch pattern"

### Style
source './style.muttrc'

## Addresses
set query_command = "~/Dotfiles/Mail/address_query.sh %s"

## GPG Stuff
set crypt_auto_sign = yes
# set crypt_opportunistic_encrypt = yes
set pgp_default_key  = 'mail@jeanclaudegraf.ch'
set crypt_chars = "SEsK" # Status keys to show

