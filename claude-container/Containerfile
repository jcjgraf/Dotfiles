FROM node:20-slim

RUN apt-get update && apt-get install -y \
    git \
    ripgrep \
    curl \
    ca-certificates \
    build-essential \
    make \
    gcc \
    g++ \
    bash \
    python3 \
    python3-pip \
    python3-venv \
    less \
    vim \
    nano \
    jq \
    unzip \
    procps \
    openssh-client \
    && rm -rf /var/lib/apt/lists/*

RUN npm install -g @anthropic-ai/claude-code

COPY entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

# Remap the node user's home to /home/app so os.homedir() matches our mount point.
# Node.js reads home from /etc/passwd, not the HOME env var, and the base image's
# "node" user (UID 1000) has home /home/node by default.
RUN usermod -d /home/app -m node && chown node:node /home/app

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
