AddKeysToAgent yes

Host aur.archlinux.org
    HostName aur.archlinux.org
    IdentityFile ~/.ssh/aur
    User aur

Host hs_local
  HostName homeserver.local
  IdentityFile ~/.ssh/id_rsa
  User jeanclaude

Host hs_remote
  HostName jeanclaudegraf.ch
  Port 5022
  IdentityFile ~/.ssh/id_rsa
  User jeanclaude

Host remarkable
    Hostname 10.11.99.1
    User root
    Port 22
    IdentityFile ~/.ssh/id_rsa
    ForwardX11 no
    ForwardAgent no
    PubkeyAcceptedKeyTypes +ssh-rsa
    HostKeyAlgorithms +ssh-rsa

Host cs_jump
    Hostname comsec-jumphost.ethz.ch
    IdentityFile ~/.ssh/id_rsa
    User jegraf
    RequestTTY yes  # Mirrors -t, for colored output

Host cn128
    Hostname ee-tik-cn128
    User jegraf
    RequestTTY yes  # Mirrors -t, for colored output
    ProxyJump cs_jump

Host cn140
    Hostname ee-tik-cn140
    User jegraf
    RequestTTY yes  # Mirrors -t, for colored output
    ProxyJump cs_jump
