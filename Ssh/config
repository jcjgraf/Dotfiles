AddKeysToAgent yes

Host aur.archlinux.org
    Hostname aur.archlinux.org
    IdentityFile ~/.ssh/aur
    User aur

Host hs
    Hostname jeanclaudegraf.ch
    Port 5022
    IdentityFile ~/.ssh/id_rsa
    User jeanclaude

Host remarkable
    Hostname 10.11.99.1
    User root
    Port 22
    IdentityFile ~/.ssh/id_rsa
    ForwardX11 no
    ForwardAgent no
    PubkeyAcceptedKeyTypes +ssh-rsa
    HostKeyAlgorithms +ssh-rsa

Host cs_jump
    # Hostname comsec-jumphost.ethz.ch
    Hostname comsec-research.ethz.ch
    IdentityFile ~/.ssh/id_rsa
    User jegraf
    RequestTTY yes  # Mirrors -t, for colored output

Host cs_jump_edu
    Hostname comsec-edu.ethz.ch
    IdentityFile ~/.ssh/id_rsa
    User jegraf
    RequestTTY yes  # Mirrors -t, for colored output

Host cn*
    Hostname ee-tik-%h
    User jegraf
    RequestTTY yes  # Mirrors -t, for colored output
    ProxyJump cs_jump
